<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard de Produção</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f5f0;color:#1a1a1a;min-height:100vh;font-size:13px}

@media(prefers-color-scheme:dark){
  body{background:#0d1117;color:#e6edf3}
  .filters,.chart-card,.kpi{background:#161b22;border-color:#30363d}
  header{background:#161b22 !important;border-color:#30363d !important}
  header h1{color:#e6edf3}
  header p,#rec-badge{color:#7d8590}
  select,input[type=date]{background:#1e2530;border-color:#30363d;color:#e6edf3}
  .tipo-btn{background:#1e2530;border-color:#30363d;color:#7d8590}
  .tipo-btn:hover{border-color:#8b949e;color:#e6edf3}
  .tipo-btn.active{background:#1a2a3a;border-color:#388bfd;color:#79c0ff}
  #upload-zone{border-color:#30363d}
  #upload-zone:hover,#upload-zone.drag{border-color:#8b949e;background:#161b22}
  .btn-sm,.btn-upload{background:#1e2530;border-color:#30363d;color:#e6edf3}
  .btn-sm:hover,.btn-upload:hover{background:#30363d}
  #progress-wrap{background:#161b22}
  #progress-bar-outer{background:#0d1117}
  .kpi-label,.kpi-sub{color:#7d8590}
  .kpi-value{color:#e6edf3}
  .chart-badge{background:#1e2530;color:#7d8590}
  .chart-title{color:#e6edf3}
  .legend{color:#7d8590}
  .f-label,.date-sep{color:#7d8590}
  .metric-toggle label{color:#7d8590;background:#1e2530;border-color:#30363d}
  .metric-toggle label:hover{border-color:#8b949e;color:#e6edf3}
  .metric-toggle input:checked + label{background:#1a2a3a;border-color:#388bfd;color:#79c0ff}
  .var-bar{background:#1e2530}
  .var-pos{background:rgba(99,153,34,.25);color:#97C459}
  .var-neg{background:rgba(226,75,74,.22);color:#F09595}
  .var-neu{background:rgba(136,135,128,.18);color:#7d8590}
}

/* Upload */
#upload-screen{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:2rem}
#upload-zone{border:1.5px dashed #c0bfb8;border-radius:12px;padding:3rem 4rem;text-align:center;cursor:pointer;transition:border-color .2s,background .2s;max-width:480px;width:100%}
#upload-zone:hover,#upload-zone.drag{border-color:#666;background:#efefea}
#upload-zone h2{font-size:16px;font-weight:500;margin-bottom:8px}
#upload-zone p{font-size:13px;color:#666;margin-bottom:1.5rem;line-height:1.6}
#upload-zone input{display:none}
.btn-upload{display:inline-block;padding:8px 20px;background:#f0f0eb;border:0.5px solid #c0bfb8;border-radius:8px;cursor:pointer;font-size:13px;font-weight:500;color:#1a1a1a;transition:background .15s}
.btn-upload:hover{background:#e0e0db}
#progress-wrap{background:#f0f0eb;border-radius:12px;padding:2rem;text-align:center;max-width:380px;margin:2rem auto;width:100%}
#progress-bar-outer{background:#ddd;border-radius:20px;height:6px;overflow:hidden;margin:12px 0}
#progress-bar-fill{height:100%;width:0%;background:#378ADD;border-radius:20px;transition:width .1s}
#progress-text{font-size:12px;color:#666}

/* Dashboard shell */
#dash{display:none}
header{background:#fff;border-bottom:0.5px solid #e0e0db;padding:12px 20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;position:sticky;top:0;z-index:100}
header h1{font-size:15px;font-weight:500}
header p{font-size:11px;color:#666;margin-top:2px}
.topbar-actions{display:flex;gap:8px;align-items:center}
.btn-sm{padding:5px 12px;background:#f0f0eb;border:0.5px solid #c0bfb8;border-radius:8px;cursor:pointer;font-size:12px;color:#1a1a1a;font-family:inherit;transition:background .15s}
.btn-sm:hover{background:#e0e0db}
#rec-badge{font-size:11px;color:#666;font-family:monospace}

/* Filters */
.filters{display:flex;gap:8px;flex-wrap:wrap;padding:12px 20px;background:#fff;border-bottom:0.5px solid #e0e0db;align-items:flex-end}
.f-group{display:flex;flex-direction:column;gap:3px}
.f-label{font-size:10px;text-transform:uppercase;letter-spacing:.5px;color:#666;font-weight:500}
select,input[type=date]{background:#f5f5f0;border:0.5px solid #c0bfb8;border-radius:8px;color:#1a1a1a;padding:5px 8px;font-size:12px;font-family:inherit;outline:none;min-width:130px;cursor:pointer}
select:focus,input[type=date]:focus{border-color:#378ADD}
.date-pair{display:flex;gap:4px;align-items:center}
.date-sep{font-size:11px;color:#666}
.tipo-btns{display:flex;gap:4px;flex-wrap:wrap}
.tipo-btn{padding:4px 10px;background:#f5f5f0;border:0.5px solid #c0bfb8;border-radius:8px;cursor:pointer;font-size:11px;font-weight:600;font-family:monospace;color:#666;transition:all .15s;white-space:nowrap}
.tipo-btn:hover{border-color:#888;color:#1a1a1a}
.tipo-btn.active{background:#e8f0fb;border-color:#378ADD;color:#185FA5}

/* Metric toggle */
.metric-toggle{display:flex;gap:3px;align-items:center;flex-shrink:0}
.metric-toggle input[type=radio]{display:none}
.metric-toggle label{padding:3px 10px;background:#f5f5f0;border:0.5px solid #c0bfb8;border-radius:6px;cursor:pointer;font-size:11px;font-weight:500;color:#666;transition:all .15s;white-space:nowrap}
.metric-toggle label:hover{border-color:#888;color:#1a1a1a}
.metric-toggle input:checked + label{background:#e8f0fb;border-color:#378ADD;color:#185FA5;font-weight:600}

/* Main */
.main{padding:16px 20px}

/* KPIs */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:10px;margin-bottom:16px}
.kpi{background:#fff;border:0.5px solid #e0e0db;border-radius:12px;padding:14px;position:relative;overflow:hidden}
.kpi::after{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.kpi.k-blue::after{background:#378ADD}.kpi.k-green::after{background:#639922}.kpi.k-red::after{background:#E24B4A}
.kpi.k-amber::after{background:#BA7517}.kpi.k-purple::after{background:#7F77DD}.kpi.k-teal::after{background:#1D9E75}
.kpi-label{font-size:10px;text-transform:uppercase;letter-spacing:.5px;color:#666;margin-bottom:6px;font-weight:500}
.kpi-value{font-size:20px;font-weight:500;font-family:monospace;letter-spacing:-1px;line-height:1;color:#1a1a1a}
.kpi-sub{font-size:11px;color:#666;margin-top:4px}

/* Charts */
.charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.chart-card{background:#fff;border:0.5px solid #e0e0db;border-radius:12px;padding:16px}
.chart-card.span2{grid-column:span 2}
.chart-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:10px;gap:8px;flex-wrap:wrap}
.chart-top-left{display:flex;flex-direction:column;gap:4px}
.chart-title{font-size:12px;font-weight:500;color:#1a1a1a}
.chart-badge{font-size:10px;color:#666;background:#f5f5f0;padding:2px 8px;border-radius:20px}
.legend{display:flex;flex-wrap:wrap;gap:12px;font-size:11px;color:#666;margin-bottom:4px}
.leg-dot{width:10px;height:10px;border-radius:2px;display:inline-block;margin-right:4px;vertical-align:middle}
.cw{position:relative;width:100%}

/* Variation bar */
.var-bar{display:flex;margin-top:8px;background:#f0f0eb;border-radius:6px;overflow:hidden;height:22px}
.var-item{display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;font-family:monospace;flex:1;white-space:nowrap;overflow:hidden;cursor:default;transition:opacity .15s}
.var-item:hover{opacity:.75}
.var-pos{background:rgba(99,153,34,.15);color:#3a6010}
.var-neg{background:rgba(226,75,74,.12);color:#a02020}
.var-neu{background:transparent;color:#888}

@media(max-width:700px){
  .charts-grid{grid-template-columns:1fr}
  .chart-card.span2{grid-column:span 1}
  .kpi-grid{grid-template-columns:repeat(2,1fr)}
  #upload-zone{padding:2rem 1.5rem}
}
</style>
</head>
<body>

<!-- Upload -->
<div id="upload-screen">
  <div id="upload-zone"
    onclick="document.getElementById('file-input').click()"
    ondragover="event.preventDefault();this.classList.add('drag')"
    ondragleave="this.classList.remove('drag')"
    ondrop="handleDrop(event)">
    <div style="font-size:40px;margin-bottom:14px;line-height:1">📊</div>
    <h2>Dashboard de Produção</h2>
    <p>Arraste e solte o arquivo .xlsx aqui<br>ou clique para selecionar</p>
    <span class="btn-upload">Selecionar arquivo</span>
    <input type="file" id="file-input" accept=".xlsx,.xls" onchange="handleFile(this.files[0])">
  </div>
  <div id="progress-wrap" style="display:none">
    <p style="font-size:13px;font-weight:500;margin-bottom:4px" id="progress-label">Processando...</p>
    <div id="progress-bar-outer"><div id="progress-bar-fill"></div></div>
    <p id="progress-text">Lendo arquivo...</p>
  </div>
</div>

<!-- Dashboard -->
<div id="dash">
  <header>
    <div>
      <h1>Dashboard de Produção</h1>
      <p id="dash-subtitle"></p>
    </div>
    <div class="topbar-actions">
      <span id="rec-badge"></span>
      <button class="btn-sm" onclick="document.getElementById('file-input2').click()">↑ Novo relatório</button>
      <input type="file" id="file-input2" style="display:none" accept=".xlsx,.xls" onchange="handleFile(this.files[0])">
    </div>
  </header>

  <div class="filters">
    <div class="f-group">
      <span class="f-label">Vigência</span>
      <div class="date-pair">
        <input type="date" id="f-vig-s"><span class="date-sep">→</span><input type="date" id="f-vig-e">
      </div>
    </div>
    <div class="f-group">
      <span class="f-label">Emissão</span>
      <div class="date-pair">
        <input type="date" id="f-em-s"><span class="date-sep">→</span><input type="date" id="f-em-e">
      </div>
    </div>
    <div class="f-group">
      <span class="f-label">Colaborador</span>
      <select id="f-col"><option value="">Todos</option></select>
    </div>
    <div class="f-group">
      <span class="f-label">Grupo de produção</span>
      <select id="f-grp"><option value="">Todos</option></select>
    </div>
    <div class="f-group">
      <span class="f-label">Ramo</span>
      <select id="f-ram"><option value="">Todos</option></select>
    </div>
    <div class="f-group">
      <span class="f-label">Seguradora</span>
      <select id="f-seg"><option value="">Todas</option></select>
    </div>
    <div class="f-group" style="flex:1;min-width:220px">
      <span class="f-label">Tipo de documento</span>
      <div class="tipo-btns" id="tipo-btns"></div>
    </div>
    <div class="f-group" style="margin-left:auto">
      <button class="btn-sm" onclick="resetFilters()">↺ Limpar filtros</button>
    </div>
  </div>

  <div class="main">
    <div class="kpi-grid" id="kpi-grid"></div>

    <div class="charts-grid">

      <!-- Evolução mensal -->
      <div class="chart-card span2">
        <div class="chart-top">
          <div class="chart-top-left">
            <span class="chart-title">Evolução mensal da produção</span>
            <div class="legend">
              <span><span class="leg-dot" style="background:#639922"></span><span id="leg-cur">Ano atual</span></span>
              <span><span class="leg-dot" style="background:#E24B4A"></span><span id="leg-prev">Ano anterior</span></span>
              <span style="font-size:10px;opacity:.55">· barra inferior = variação % vs. ano anterior</span>
            </div>
          </div>
          <div class="metric-toggle">
            <input type="radio" name="mt-evol" id="mt-evol-p" value="premio" checked onchange="render()">
            <label for="mt-evol-p">Prêmio</label>
            <input type="radio" name="mt-evol" id="mt-evol-c" value="comissao" onchange="render()">
            <label for="mt-evol-c">Comissão</label>
          </div>
        </div>
        <div class="cw" style="height:210px"><canvas id="ch-evolucao"></canvas></div>
        <div class="var-bar" id="var-bar"></div>
      </div>

      <!-- Cancelamentos -->
      <div class="chart-card span2">
        <div class="chart-top">
          <span class="chart-title">Cancelamentos por motivo</span>
          <span class="chart-badge" id="cancel-badge">—</span>
        </div>
        <div class="cw" id="cancel-wrap" style="height:240px"><canvas id="ch-cancel"></canvas></div>
      </div>

      <!-- Seguradora -->
      <div class="chart-card">
        <div class="chart-top">
          <span class="chart-title">Concentração por seguradora</span>
          <div class="metric-toggle">
            <input type="radio" name="mt-seg" id="mt-seg-p" value="premio" checked onchange="renderSeguradora()">
            <label for="mt-seg-p">Prêmio</label>
            <input type="radio" name="mt-seg" id="mt-seg-c" value="comissao" onchange="renderSeguradora()">
            <label for="mt-seg-c">Comissão</label>
          </div>
        </div>
        <div class="legend" id="seg-legend"></div>
        <div class="cw" style="height:200px"><canvas id="ch-seg"></canvas></div>
      </div>

      <!-- Ramo -->
      <div class="chart-card">
        <div class="chart-top">
          <span class="chart-title">Produção por ramo</span>
          <div class="metric-toggle">
            <input type="radio" name="mt-ramo" id="mt-ramo-p" value="premio" checked onchange="renderRamo()">
            <label for="mt-ramo-p">Prêmio</label>
            <input type="radio" name="mt-ramo" id="mt-ramo-c" value="comissao" onchange="renderRamo()">
            <label for="mt-ramo-c">Comissão</label>
          </div>
        </div>
        <div class="cw" style="height:200px"><canvas id="ch-ramo"></canvas></div>
      </div>

    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
// ── State ─────────────────────────────────────────────────────────────────────
let ALL = [], FD = [];
let activeTipos = new Set();
const charts = {};

// ── Column mapping ────────────────────────────────────────────────────────────
const COL = {
  tipo:'TIPO DE NEGÓCIO', vig:'INÍCIO DE VIGÊNCIA', em:'DATA EMISSÃO',
  fim:'TÉRMINO DE VIGÊNCIA', cli:'CLIENTE', seg:'SEGURADORA',
  ramo:'RAMO', grp:'GRUPO DE PRODUÇÃO', premio:'PRÊMIO', com:'COMISSÃO',
  colab:'COLABORADOR', sit:'SITUAÇÃO', motivo:'MOTIVO CANCELAMENTO', cancel:'DATA CANCELAMENTO'
};

const TIPO_LABELS = {
  R:'R — Renovação', N:'N — Negócio novo', ER:'ER — Endosso renov.',
  EN:'EN — Endosso novo', CR:'CR — Cancel. renov.', CN:'CN — Cancel. novo'
};

const PALETA = [
  '#378ADD','#639922','#E24B4A','#BA7517','#534AB7',
  '#1D9E75','#D4537E','#888780','#5DCAA5','#F09595','#97C459','#BC8CFF'
];

// ── Dark mode helpers (Chart.js cannot read CSS variables) ────────────────────
const dark = () => window.matchMedia('(prefers-color-scheme: dark)').matches;
const axisClr  = () => dark() ? '#8b949e' : '#888888';
const gridClr  = () => dark() ? 'rgba(255,255,255,0.07)' : 'rgba(0,0,0,0.055)';
const labelClr = () => dark() ? '#c9d1d9' : '#444444';
const borderClr= () => dark() ? '#161b22' : '#ffffff';

// ── Utils ─────────────────────────────────────────────────────────────────────
const fBRL = v => (!v && v !== 0) ? '—' :
  new Intl.NumberFormat('pt-BR',{style:'currency',currency:'BRL',maximumFractionDigits:0}).format(v);
const fN   = v => new Intl.NumberFormat('pt-BR').format(Math.round(v));
const fP   = v => (v*100).toFixed(1)+'%';
const fShort = v => v>=1e6 ? 'R$'+(v/1e6).toFixed(1)+'M' : v>=1e3 ? 'R$'+(v/1e3).toFixed(0)+'k' : 'R$'+Math.round(v);

function toDate(v) {
  if (!v) return null;
  if (v instanceof Date) return v;
  if (typeof v === 'number') return new Date(Math.round((v-25569)*86400*1000));
  if (typeof v === 'string' && /^\d{4}-\d{2}-\d{2}$/.test(v)) return new Date(v+'T00:00:00');
  const p = new Date(v); return isNaN(p) ? null : p;
}
const fmtD = d => { if(!d) return ''; const dt=toDate(d); return dt?dt.toISOString().slice(0,10):''; };
const today    = () => new Date();
const addDays  = (d,n) => { const r=new Date(d); r.setDate(r.getDate()+n); return r; };
const getMetric= name => { const el=document.querySelector(`input[name="${name}"]:checked`); return el?el.value:'premio'; };

function mkChart(id, cfg) {
  if (charts[id]) charts[id].destroy();
  const c = document.getElementById(id);
  if (!c) return;
  charts[id] = new Chart(c, cfg);
}

// ── File handling ─────────────────────────────────────────────────────────────
function handleDrop(e) {
  e.preventDefault();
  document.getElementById('upload-zone').classList.remove('drag');
  const f = e.dataTransfer.files[0]; if (f) handleFile(f);
}
function setProgress(pct, msg) {
  document.getElementById('progress-bar-fill').style.width = pct+'%';
  document.getElementById('progress-text').textContent = msg;
}
function handleFile(file) {
  if (!file) return;
  document.getElementById('upload-zone').style.display = 'none';
  document.getElementById('progress-wrap').style.display = 'block';
  document.getElementById('progress-label').textContent = file.name;
  setProgress(10,'Lendo arquivo...');
  const reader = new FileReader();
  reader.onload = e => {
    setProgress(30,'Processando planilha...');
    setTimeout(() => {
      try {
        const wb   = XLSX.read(e.target.result,{type:'array',cellDates:true});
        setProgress(60,'Mapeando colunas...');
        const rows = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]],{defval:''});
        setProgress(80,'Calculando indicadores...');
        ALL = rows.map(r => ({
          tipo:   String(r[COL.tipo]  ||'').trim(),
          vig:    toDate(r[COL.vig]),   em:     toDate(r[COL.em]),
          fim:    toDate(r[COL.fim]),   cli:    String(r[COL.cli]   ||''),
          seg:    String(r[COL.seg]   ||''),   ramo:   String(r[COL.ramo] ||''),
          grp:    String(r[COL.grp]   ||''),   premio: parseFloat(r[COL.premio])||0,
          com:    parseFloat(r[COL.com])||0,   colab:  String(r[COL.colab]||''),
          sit:    String(r[COL.sit]   ||''),   motivo: String(r[COL.motivo]||''),
          cancel: toDate(r[COL.cancel])
        }));
        setProgress(100,'Pronto!');
        setTimeout(() => initDash(file.name), 300);
      } catch(err) {
        document.getElementById('progress-label').textContent = 'Erro ao processar arquivo';
        document.getElementById('progress-text').textContent  = err.message;
        console.error(err);
      }
    }, 50);
  };
  reader.readAsArrayBuffer(file);
}

// ── Init ──────────────────────────────────────────────────────────────────────
function initDash(fname) {
  FD = [...ALL]; activeTipos = new Set();
  document.getElementById('upload-screen').style.display = 'none';
  document.getElementById('dash').style.display = 'block';
  document.getElementById('dash-subtitle').textContent = fname + ' · ' + fN(ALL.length) + ' registros';
  document.getElementById('rec-badge').textContent     = fN(ALL.length) + ' registros';
  populateFilters(); buildTipoBtns(); render();
}

// ── Filters ───────────────────────────────────────────────────────────────────
function populateFilters() {
  const popSel = (id, vals) => {
    const s = document.getElementById(id), first = s.options[0];
    s.innerHTML = ''; s.appendChild(first);
    vals.sort().forEach(v => { const o=document.createElement('option'); o.value=o.textContent=v; s.appendChild(o); });
  };
  popSel('f-col',[...new Set(ALL.map(r=>r.colab).filter(Boolean))]);
  popSel('f-grp',[...new Set(ALL.map(r=>r.grp).filter(Boolean))]);
  popSel('f-ram',[...new Set(ALL.map(r=>r.ramo).filter(Boolean))]);
  popSel('f-seg',[...new Set(ALL.map(r=>r.seg).filter(Boolean))]);
  ['f-col','f-grp','f-ram','f-seg'].forEach(id=>document.getElementById(id).addEventListener('change',applyFilters));
  ['f-vig-s','f-vig-e','f-em-s','f-em-e'].forEach(id=>document.getElementById(id).addEventListener('change',applyFilters));
}
function buildTipoBtns() {
  const tipos=[...new Set(ALL.map(r=>r.tipo).filter(Boolean))].sort();
  const c=document.getElementById('tipo-btns'); c.innerHTML='';
  tipos.forEach(t=>{
    const btn=document.createElement('button');
    btn.className='tipo-btn'; btn.textContent=TIPO_LABELS[t]||t; btn.dataset.tipo=t;
    btn.addEventListener('click',()=>toggleTipo(t,btn)); c.appendChild(btn);
  });
}
function toggleTipo(t,btn) {
  activeTipos.has(t)?(activeTipos.delete(t),btn.classList.remove('active')):(activeTipos.add(t),btn.classList.add('active'));
  applyFilters();
}
function applyFilters() {
  const vs=document.getElementById('f-vig-s').value, ve=document.getElementById('f-vig-e').value;
  const es=document.getElementById('f-em-s').value,  ee=document.getElementById('f-em-e').value;
  const col=document.getElementById('f-col').value,  grp=document.getElementById('f-grp').value;
  const ram=document.getElementById('f-ram').value,  seg=document.getElementById('f-seg').value;
  FD=ALL.filter(r=>{
    if(vs&&r.vig&&fmtD(r.vig)<vs) return false;
    if(ve&&r.vig&&fmtD(r.vig)>ve) return false;
    if(es&&r.em&&fmtD(r.em)<es)   return false;
    if(ee&&r.em&&fmtD(r.em)>ee)   return false;
    if(col&&r.colab!==col) return false;
    if(grp&&r.grp!==grp)   return false;
    if(ram&&r.ramo!==ram)   return false;
    if(seg&&r.seg!==seg)    return false;
    if(activeTipos.size>0&&!activeTipos.has(r.tipo)) return false;
    return true;
  });
  document.getElementById('rec-badge').textContent=fN(FD.length)+' registros';
  render();
}
function resetFilters() {
  ['f-vig-s','f-vig-e','f-em-s','f-em-e'].forEach(id=>document.getElementById(id).value='');
  ['f-col','f-grp','f-ram','f-seg'].forEach(id=>document.getElementById(id).value='');
  activeTipos=new Set();
  document.querySelectorAll('.tipo-btn').forEach(b=>b.classList.remove('active'));
  FD=[...ALL]; document.getElementById('rec-badge').textContent=fN(FD.length)+' registros';
  render();
}

// ── Render ────────────────────────────────────────────────────────────────────
function render(){ renderKPIs(); renderEvolucao(); renderCancelamentos(); renderSeguradora(); renderRamo(); }

// ── KPIs ──────────────────────────────────────────────────────────────────────
function renderKPIs() {
  const d=FD, premio=d.reduce((s,r)=>s+r.premio,0), com=d.reduce((s,r)=>s+r.com,0);
  const cliSet=new Set(d.map(r=>r.cli)), withP=d.filter(r=>r.premio>0);
  const ticket=withP.length?withP.reduce((s,r)=>s+r.premio,0)/withP.length:0;
  const cancel=d.filter(r=>r.sit==='Cancelada'), churn=d.length?cancel.length/d.length:0;
  const todayStr=fmtD(today()), d30=fmtD(addDays(today(),30));
  const venc30=d.filter(r=>r.fim&&fmtD(r.fim)>=todayStr&&fmtD(r.fim)<=d30).length;
  const renov=d.filter(r=>r.tipo==='R').length;
  const kpis=[
    {l:'Prêmio total',       v:fBRL(premio),   s:fN(d.length)+' apólices',                      c:'k-blue'  },
    {l:'Comissão total',     v:fBRL(com),       s:premio?fP(com/premio)+' do prêmio':'—',         c:'k-green' },
    {l:'Ticket médio',       v:fBRL(ticket),    s:fN(withP.length)+' c/ prêmio',                  c:'k-purple'},
    {l:'Clientes únicos',    v:fN(cliSet.size), s:'na seleção atual',                              c:'k-teal'  },
    {l:'Churn (canceladas)', v:fP(churn),       s:fN(cancel.length)+' apólices',                   c:'k-red'   },
    {l:'Vencendo em 30d',    v:fN(venc30),      s:'renovações pendentes',                          c:'k-amber' },
    {l:'Renovações',         v:fN(renov),       s:fP(d.length?renov/d.length:0)+' do total',      c:'k-blue'  },
    {l:'Comissão média',     v:fBRL(withP.length?com/withP.length:0), s:'por apólice',             c:'k-green' },
  ];
  document.getElementById('kpi-grid').innerHTML=kpis.map(k=>
    `<div class="kpi ${k.c}"><div class="kpi-label">${k.l}</div><div class="kpi-value">${k.v}</div><div class="kpi-sub">${k.s}</div></div>`
  ).join('');
}

// ── Evolução mensal ───────────────────────────────────────────────────────────
function renderEvolucao() {
  const field   = getMetric('mt-evol')==='comissao'?'com':'premio';
  const curYear = today().getFullYear(), prevYear = curYear-1;
  const cur={}, prev={};
  FD.forEach(r=>{
    if(!r.vig) return;
    const dt=r.vig instanceof Date?r.vig:toDate(r.vig); if(!dt) return;
    const y=dt.getFullYear(), m=String(dt.getMonth()+1).padStart(2,'0');
    if(y===curYear)  cur[m] =(cur[m] ||0)+r[field];
    else if(y===prevYear) prev[m]=(prev[m]||0)+r[field];
  });
  const months=['01','02','03','04','05','06','07','08','09','10','11','12'];
  const mLabels=['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  document.getElementById('leg-cur').textContent  = String(curYear);
  document.getElementById('leg-prev').textContent = String(prevYear);
  const ac=axisClr(), gc=gridClr();
  mkChart('ch-evolucao',{
    type:'line',
    data:{labels:mLabels,datasets:[
      {label:String(curYear), data:months.map(m=>cur[m]||0),
       borderColor:'#639922',backgroundColor:'rgba(99,153,34,0.08)',
       fill:true,tension:.35,pointRadius:4,pointBackgroundColor:'#639922',borderWidth:2},
      {label:String(prevYear),data:months.map(m=>prev[m]||0),
       borderColor:'#E24B4A',backgroundColor:'rgba(226,75,74,0.06)',
       fill:true,tension:.35,pointRadius:4,pointBackgroundColor:'#E24B4A',borderWidth:2,borderDash:[5,3]}
    ]},
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>ctx.dataset.label+': '+fBRL(ctx.raw)}}},
      scales:{
        x:{ticks:{color:ac,font:{size:11}},grid:{color:gc}},
        y:{ticks:{color:ac,font:{size:10},callback:fShort},grid:{color:gc}}
      }
    }
  });
  // Variation bar
  document.getElementById('var-bar').innerHTML = months.map((m,i)=>{
    const c=cur[m]||0, p=prev[m]||0;
    let cls='var-neu', txt='—';
    if(p>0){ const pct=((c-p)/p)*100; cls=pct>=0?'var-pos':'var-neg'; txt=(pct>=0?'+':'')+pct.toFixed(1)+'%'; }
    else if(c>0){ cls='var-pos'; txt='novo'; }
    return `<div class="var-item ${cls}" title="${mLabels[i]}: ${txt}">${txt}</div>`;
  }).join('');
}

// ── Cancelamentos ─────────────────────────────────────────────────────────────
function renderCancelamentos() {
  const canceladas=FD.filter(r=>r.sit==='Cancelada');
  document.getElementById('cancel-badge').textContent=fN(canceladas.length)+' cancelamentos';
  const mot={};
  canceladas.forEach(r=>{ const m=r.motivo||'Não informado'; mot[m]=(mot[m]||0)+1; });
  const sorted=Object.entries(mot).sort((a,b)=>b[1]-a[1]).slice(0,12);
  document.getElementById('cancel-wrap').style.height=Math.max(220,sorted.length*38+60)+'px';
  const ac=axisClr(), lc=labelClr(), gc=gridClr();
  mkChart('ch-cancel',{
    type:'bar',
    data:{
      labels:sorted.map(m=>m[0].length>35?m[0].slice(0,32)+'...':m[0]),
      datasets:[{data:sorted.map(m=>m[1]),
        backgroundColor:sorted.map((_,i)=>i===0?'rgba(226,75,74,.85)':i<=2?'rgba(226,75,74,.6)':'rgba(226,75,74,.4)'),
        borderRadius:4}]
    },
    options:{
      indexAxis:'y',responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>ctx.raw+' apólices'}}},
      scales:{
        x:{ticks:{color:ac,font:{size:10}},grid:{color:gc}},
        y:{ticks:{color:lc,font:{size:11}},grid:{display:false}}
      }
    }
  });
}

// ── Seguradora ────────────────────────────────────────────────────────────────
function renderSeguradora() {
  const field=getMetric('mt-seg')==='comissao'?'com':'premio';
  const bySeg={};
  FD.forEach(r=>{ if(r.seg) bySeg[r.seg]=(bySeg[r.seg]||0)+r[field]; });
  const sorted=Object.entries(bySeg).sort((a,b)=>b[1]-a[1]);
  const top8=sorted.slice(0,8), outros=sorted.slice(8).reduce((s,e)=>s+e[1],0);
  const items=outros>0?[...top8,['Outros',outros]]:top8;
  const total=items.reduce((s,e)=>s+e[1],0);
  const short=n=>n.replace(' CIA DE SEGUROS GERAIS S/A','').replace(' CIA NAC DE SEGUROS S/A','')
    .replace(' SEGUROS S/A','').replace(' SEGURADORA S/A','').replace(' SEGURADORA','')
    .replace(' SEGS CORPORATIVOS SA','').trim();
  const labels=items.map(e=>short(e[0])), colors=PALETA.slice(0,items.length);
  document.getElementById('seg-legend').innerHTML=labels.map((l,i)=>
    `<span><span class="leg-dot" style="background:${colors[i]}"></span>${l} ${fP(total?items[i][1]/total:0)}</span>`
  ).join('');
  mkChart('ch-seg',{
    type:'doughnut',
    data:{labels,datasets:[{data:items.map(e=>e[1]),backgroundColor:colors,borderWidth:2,borderColor:borderClr()}]},
    options:{
      responsive:true,maintainAspectRatio:false,cutout:'58%',
      plugins:{legend:{display:false},
        tooltip:{callbacks:{label:ctx=>ctx.label+': '+fBRL(ctx.raw)+' ('+fP(total?ctx.raw/total:0)+')'}}}
    }
  });
}

// ── Ramo ──────────────────────────────────────────────────────────────────────
function renderRamo() {
  const field=getMetric('mt-ramo')==='comissao'?'com':'premio';
  const byR={};
  FD.forEach(r=>{ if(r.ramo) byR[r.ramo]=(byR[r.ramo]||0)+r[field]; });
  const sorted=Object.entries(byR).sort((a,b)=>b[1]-a[1]).slice(0,8);
  const short=n=>n.replace('AUTOMÓVEL - CASCO','Auto — casco').replace('COMPREENSIVO RESIDENCIAL','Comp. residencial')
    .replace('COMPREENSIVO EMPRESARIAL','Comp. empresarial').replace('COMPREENSIVO CONDOMÍNIO','Comp. condomínio')
    .replace('RC PROFISSIONAL','RC profissional').replace('VIDA INDIVIDUAL','Vida individual')
    .replace('VIDA EM GRUPO','Vida em grupo').replace('TRANSPORTE NACIONAL','Transporte nac.')
    .replace('RISCOS DIVERSOS','Riscos diversos').replace('RISCOS DE ENGENHARIA','Riscos engenharia')
    .replace('OUTROS RAMOS','Outros ramos').toLowerCase().replace(/^\w/,c=>c.toUpperCase());
  const ac=axisClr(), lc=labelClr(), gc=gridClr();
  mkChart('ch-ramo',{
    type:'bar',
    data:{labels:sorted.map(e=>short(e[0])),
      datasets:[{data:sorted.map(e=>e[1]),backgroundColor:PALETA.slice(0,sorted.length),borderRadius:4}]},
    options:{
      indexAxis:'y',responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>fBRL(ctx.raw)}}},
      scales:{
        x:{ticks:{color:ac,font:{size:10},callback:fShort},grid:{color:gc}},
        y:{ticks:{color:lc,font:{size:11}},grid:{display:false}}
      }
    }
  });
}

// Re-render when OS switches theme so chart colors update
window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => { if(FD.length) render(); });
</script>
